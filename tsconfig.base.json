{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "resolveJsonModule": true,
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["apps/web/src/*"],
      "@core": ["packages/core/src/index.ts"],
      "@core/*": ["packages/core/src/*"],
      "@ui": ["packages/ui/src/index.ts"],
      "@ui/*": ["packages/ui/src/*"]
    }
  }
}


